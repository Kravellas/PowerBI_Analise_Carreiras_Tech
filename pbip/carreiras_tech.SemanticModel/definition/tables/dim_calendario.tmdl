	partition dim_calendario = calculated
		mode: import
		source = ```
				
				/* Cria uma tabela de calendário contínua e adiciona colunas de apoio */
				ADDCOLUMNS (
				    // Cria datas diárias cobrindo o ano de 2023
				    CALENDAR(DATE(2023, 1, 1), DATE(2023, 12, 31)), 
				    "Ano", YEAR ( [Date] ),
				    "Mes_Numero", MONTH ( [Date] ),
				    "Mes_Nome", FORMAT ( [Date], "MMMM" ),
				    "Trimestre", "Q" & FORMAT ( [Date], "Q" ),
				    "Ano_Mes", FORMAT ( [Date], "YYYY-MM" )
				)
				```

	annotation PBI_Id = 692097fb5d2744d8887565f3d41b6e26

